<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Form View -->
        <record id="endorsement_request_form_view" model="ir.ui.view">
            <field name="name">endorsement.request.form</field>
            <field name="model">endorsement.request</field>
            <field name="arch" type="xml">
                <form string="Endorsement Request">
                    <header>
                        <button name="action_submit" string="Submit"
                                type="object" class="oe_highlight"
                                invisible="state != 'draft'"/>
                        <button name="action_approve" string="Approve"
                                type="object" class="btn-success"
                                invisible="state != 'pending'"
                                groups="core_marketplace.marketplace_officer_group,core_ambassador.marketplace_ambassador_group"/>
                        <button name="action_reject" string="Reject"
                                type="object" class="btn-danger"
                                invisible="state != 'pending'"
                                groups="core_marketplace.marketplace_officer_group,core_ambassador.marketplace_ambassador_group"/>
                        <button name="action_cancel" string="Cancel"
                                type="object"
                                invisible="state not in ('draft', 'pending')"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,pending,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="Request">
                                <field name="seller_id"/>
                                <field name="ambassador_id"/>
                                <field name="product_id"/>
                            </group>
                            <group string="Dates">
                                <field name="requested_date"/>
                                <field name="responded_date"/>
                                <field name="endorsement_id"/>
                            </group>
                        </group>
                        <group string="Messages">
                            <field name="message" placeholder="Message to ambassador..."/>
                            <field name="response_message" placeholder="Ambassador response..."/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="endorsement_request_tree_view" model="ir.ui.view">
            <field name="name">endorsement.request.tree</field>
            <field name="model">endorsement.request</field>
            <field name="arch" type="xml">
                <list string="Endorsement Requests"
                      decoration-info="state == 'pending'"
                      decoration-success="state == 'approved'"
                      decoration-danger="state == 'rejected'">
                    <field name="name"/>
                    <field name="seller_id"/>
                    <field name="ambassador_id"/>
                    <field name="product_id"/>
                    <field name="state"/>
                    <field name="requested_date"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="endorsement_request_search_view" model="ir.ui.view">
            <field name="name">endorsement.request.search</field>
            <field name="model">endorsement.request</field>
            <field name="arch" type="xml">
                <search string="Search Requests">
                    <field name="name"/>
                    <field name="seller_id"/>
                    <field name="ambassador_id"/>
                    <field name="product_id"/>
                    <filter string="Pending" name="pending"
                            domain="[('state', '=', 'pending')]"/>
                    <filter string="Approved" name="approved"
                            domain="[('state', '=', 'approved')]"/>
                    <filter string="Rejected" name="rejected"
                            domain="[('state', '=', 'rejected')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_state"
                                context="{'group_by': 'state'}"/>
                        <filter string="Ambassador" name="group_ambassador"
                                context="{'group_by': 'ambassador_id'}"/>
                        <filter string="Seller" name="group_seller"
                                context="{'group_by': 'seller_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_endorsement_request_list" model="ir.actions.act_window">
            <field name="name">Endorsement Requests</field>
            <field name="res_model">endorsement.request</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_pending': 1}</field>
        </record>

    </data>
</odoo>
