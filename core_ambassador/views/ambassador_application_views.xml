<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Form View -->
        <record id="ambassador_application_form_view" model="ir.ui.view">
            <field name="name">ambassador.application.form</field>
            <field name="model">ambassador.application</field>
            <field name="arch" type="xml">
                <form string="Ambassador Application">
                    <header>
                        <button name="action_submit" string="Submit"
                                type="object" class="oe_highlight"
                                invisible="state != 'draft'"/>
                        <button name="action_review" string="Start Review"
                                type="object" class="oe_highlight"
                                invisible="state != 'submitted'"
                                groups="core_marketplace.marketplace_officer_group"/>
                        <button name="action_approve" string="Approve"
                                type="object" class="btn-success"
                                invisible="state not in ('submitted', 'under_review')"
                                groups="core_marketplace.marketplace_officer_group"/>
                        <button name="action_reject" string="Reject"
                                type="object" class="btn-danger"
                                invisible="state not in ('submitted', 'under_review')"
                                groups="core_marketplace.marketplace_officer_group"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,submitted,under_review,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="Applicant">
                                <field name="partner_id"/>
                                <field name="full_name"/>
                                <field name="phone"/>
                                <field name="email"/>
                            </group>
                            <group string="Tier &amp; Review">
                                <field name="requested_tier"/>
                                <field name="approved_tier"
                                       invisible="state not in ('approved',)"
                                       groups="core_marketplace.marketplace_officer_group"/>
                                <field name="submitted_date"/>
                                <field name="reviewed_date"/>
                                <field name="reviewed_by"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="expertise" string="Expertise">
                                <group>
                                    <field name="specialty_ids" widget="many2many_tags"/>
                                    <field name="bio" placeholder="Brief introduction..."/>
                                    <field name="experience" placeholder="Relevant experience..."/>
                                    <field name="motivation" placeholder="Why do you want to be an ambassador?"/>
                                </group>
                            </page>
                            <page name="social" string="Social Media">
                                <group>
                                    <field name="social_youtube" widget="url"/>
                                    <field name="social_facebook" widget="url"/>
                                    <field name="social_tiktok" widget="url"/>
                                    <field name="social_instagram" widget="url"/>
                                    <field name="portfolio_url" widget="url"/>
                                </group>
                            </page>
                            <page name="review" string="Review"
                                  invisible="state not in ('rejected',)"
                                  groups="core_marketplace.marketplace_officer_group">
                                <group>
                                    <field name="rejection_reason"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="ambassador_application_tree_view" model="ir.ui.view">
            <field name="name">ambassador.application.tree</field>
            <field name="model">ambassador.application</field>
            <field name="arch" type="xml">
                <list string="Ambassador Applications"
                      decoration-info="state == 'submitted'"
                      decoration-warning="state == 'under_review'"
                      decoration-success="state == 'approved'"
                      decoration-danger="state == 'rejected'">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="full_name"/>
                    <field name="requested_tier"/>
                    <field name="submitted_date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="ambassador_application_search_view" model="ir.ui.view">
            <field name="name">ambassador.application.search</field>
            <field name="model">ambassador.application</field>
            <field name="arch" type="xml">
                <search string="Search Applications">
                    <field name="name"/>
                    <field name="full_name"/>
                    <field name="partner_id"/>
                    <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                    <filter string="Under Review" name="under_review" domain="[('state', '=', 'under_review')]"/>
                    <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                    <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Tier" name="group_tier" context="{'group_by': 'requested_tier'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_ambassador_application_list" model="ir.actions.act_window">
            <field name="name">Ambassador Applications</field>
            <field name="res_model">ambassador.application</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_submitted': 1}</field>
        </record>

    </data>
</odoo>
