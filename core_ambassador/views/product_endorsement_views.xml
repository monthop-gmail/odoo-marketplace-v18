<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Form View -->
        <record id="product_endorsement_form_view" model="ir.ui.view">
            <field name="name">product.endorsement.form</field>
            <field name="model">product.endorsement</field>
            <field name="arch" type="xml">
                <form string="Product Endorsement">
                    <header>
                        <button name="action_revoke" string="Revoke"
                                type="object" class="btn-danger"
                                invisible="state != 'active'"
                                groups="core_marketplace.marketplace_officer_group"/>
                        <button name="action_reactivate" string="Reactivate"
                                type="object" class="oe_highlight"
                                invisible="state != 'revoked'"
                                groups="core_marketplace.marketplace_officer_group"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group string="Endorsement">
                                <field name="ambassador_id"/>
                                <field name="product_id"/>
                                <field name="seller_id"/>
                                <field name="request_id"/>
                            </group>
                            <group string="Details">
                                <field name="endorsed_date"/>
                                <field name="expiry_date"/>
                                <field name="rating"/>
                                <field name="endorsement_video_url" widget="url"/>
                            </group>
                        </group>
                        <group string="Endorsement Review">
                            <field name="endorsement_text"/>
                        </group>
                        <group string="Analytics" invisible="1">
                            <field name="click_count"/>
                            <field name="order_count"/>
                            <field name="total_sales"/>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="product_endorsement_tree_view" model="ir.ui.view">
            <field name="name">product.endorsement.tree</field>
            <field name="model">product.endorsement</field>
            <field name="arch" type="xml">
                <list string="Product Endorsements"
                      decoration-success="state == 'active'"
                      decoration-muted="state in ('expired', 'revoked')">
                    <field name="ambassador_id"/>
                    <field name="product_id"/>
                    <field name="seller_id"/>
                    <field name="state"/>
                    <field name="endorsed_date"/>
                    <field name="rating"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="product_endorsement_search_view" model="ir.ui.view">
            <field name="name">product.endorsement.search</field>
            <field name="model">product.endorsement</field>
            <field name="arch" type="xml">
                <search string="Search Endorsements">
                    <field name="ambassador_id"/>
                    <field name="product_id"/>
                    <field name="seller_id"/>
                    <filter string="Active" name="active"
                            domain="[('state', '=', 'active')]"/>
                    <filter string="Revoked" name="revoked"
                            domain="[('state', '=', 'revoked')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Ambassador" name="group_ambassador"
                                context="{'group_by': 'ambassador_id'}"/>
                        <filter string="Seller" name="group_seller"
                                context="{'group_by': 'seller_id'}"/>
                        <filter string="Status" name="group_state"
                                context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_product_endorsement_list" model="ir.actions.act_window">
            <field name="name">Product Endorsements</field>
            <field name="res_model">product.endorsement</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1}</field>
        </record>

    </data>
</odoo>
