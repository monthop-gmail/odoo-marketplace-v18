<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="sequence_ambassador_application" model="ir.sequence">
            <field name="name">Ambassador Application</field>
            <field name="code">ambassador.application</field>
            <field name="prefix">AMB-APP/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="sequence_endorsement_request" model="ir.sequence">
            <field name="name">Endorsement Request</field>
            <field name="code">endorsement.request</field>
            <field name="prefix">END-REQ/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
