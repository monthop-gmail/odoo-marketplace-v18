<odoo>
	<data>

		<record id="stock_picking_stock_tree_view_for_mp" model="ir.ui.view">
			<field name="name">Picking Stock For Marketplace</field>
            <field name="priority">20</field>
			<field name="model">stock.picking</field>
			<field name="arch" type="xml">
                <list create="0" decoration-info="state == 'draft'" decoration-muted="state == 'cancel'" decoration-danger="state not in ('cancel', 'done') and scheduled_date &lt; current_date" string="Picking list" default_order="id desc">
                    <field name="name"/>
                    <field name="location_dest_id"/>
                    <field name="partner_id" string="Customer"/>
					<field name="marketplace_seller_id" string="Seller" groups="core_marketplace.marketplace_officer_group"/>
                    <field name="date" invisible="1"/>
                    <field name="scheduled_date"/>
                    <field name="origin"/>
                    <field name="group_id" invisible="1"/>
                    <field name="backorder_id"/>
                    <field name="state"/>
                    <field name="priority" invisible="1"/>
                    <field name="picking_type_id" invisible="1"/>
                </list>
            </field>
		</record>

		<record model="ir.ui.view" id="picking_stock_kanban_view_for_mp">
            <field name="name">marketplace.stock.picking.kanban</field>
            <field name="model">stock.picking</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" create="0" disable_draggable="true">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="location_dest_id"/>
                    <field name="state"/>
                    <field name="date"/>
                    <templates>
                        <t t-name="card">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                                <div class="o_kanban_record_top mb8">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><span><t t-esc="record.name.value"/></span></strong>
                                    </div>
                                    <strong>
										<field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'cancel': 'info', 'none': 'danger', 'waiting': 'warning', 'confirmed': 'warning', 'partially_available': 'warning', 'done': 'success'}}"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
										<strong> Customer </strong>
                                        <t t-esc="record.partner_id.value"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <t t-esc="record.date.value and record.date.value.split(' ')[0] or False"/>
                                    </div>
                                </div>
								<div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
										<strong groups="core_marketplace.marketplace_officer_group"> Seller: </strong>
										<field name="marketplace_seller_id" groups="core_marketplace.marketplace_officer_group"/>
									</div>
                                    <div class="oe_kanban_bottom_right">
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

		<!-- Simplified marketplace stock.picking form view for Odoo 18 -->
		<record id="marketplace_picking_stock_modified_form_view" model="ir.ui.view">
			<field name="name">Marketplace Stock Picking</field>
			<field name="model">stock.picking</field>
			<field name="inherit_id" ref="stock.view_picking_form"/>
			<field name="priority">100</field>
            <field name="arch" type="xml">
                <!-- Add marketplace seller field to the form -->
                <field name="partner_id" position="after">
                    <field name="marketplace_seller_id" string="Seller" groups="core_marketplace.marketplace_officer_group" readonly="1"/>
                </field>
            </field>
        </record>
        <!-- <field name="weight_uom_id" nolabel="1" class="oe_inline" style="margin-left:5px" widget="selection"/> -->

        <!-- Commented out: make_carrier_writeable_to_manager - incompatible with Odoo 18 simplified form -->
		<!-- <record id="make_carrier_writeable_to_manager" model="ir.ui.view">
			<field name="name">Writeable Carrier</field>
			<field name="model">stock.picking</field>
			<field name="inherit_id" ref="core_marketplace.marketplace_picking_stock_modified_form_view"/>
			...
		</record> -->

		<record id="stock_picking_stock_move_tree_view_for_mp" model="ir.ui.view">
			<field name="name">Stock Move For Marketplace</field>
			<field name="model">stock.move</field>
			<field name="arch" type="xml">
				<list decoration-muted="state == 'cancel'" decoration-danger="(state not in ('cancel','done')) and date > current_date" string="Moves" create="0" default_order="id desc">
                    <field name="date" groups="base.group_no_one"/>
                    <field name="reference"/>
                    <field name="picking_type_id" invisible="1"/>
                    <field name="create_date" invisible="1" groups="base.group_no_one"/>
                    <field name="product_id"/>
					<field name="marketplace_seller_id" groups="core_marketplace.marketplace_officer_group"/>
                    <field name="location_id" groups="stock.group_stock_multi_locations" string="From"/>
                    <field name="location_dest_id" groups="stock.group_stock_multi_locations" string="To"/>
                    <field name="product_uom_qty"/>
                    <field name="product_uom" options="{'no_open': True, 'no_create': True}" string="Unit of Measure" groups="uom.group_uom"/>
					<field name="date" groups="base.group_no_one"/>
                    <field name="state"/>
					<field name="product_uom_category_id" invisible="1"/>
                </list>
			</field>
		</record>

		<record id="stock_move_kanban_view_for_mp" model="ir.ui.view">
            <field name="name">stock.move.kanban</field>
            <field name="model">stock.move</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" create="0" disable_draggable="true">
                    <field name="name"/>
                    <field name="product_id"/>
                    <field name="date"/>
                    <field name="priority"/>
                    <field name="state"/>
					<field name="marketplace_seller_id"/>
					<field name="product_uom_category_id"/>
                    <templates>
                        <t t-name="card">
                            <div t-attf-class="oe_kanban_global_click">
								<div class="o_kanban_record_top mb8">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><span><field name="product_id"/></span></strong>
                                    </div>
                                    <strong>
										<field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'cancel': 'danger', 'assigned': 'success', 'confirmed': 'info'}}"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_body"/>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
										<strong groups="core_marketplace.marketplace_officer_group"> Seller: </strong>
										<field name="marketplace_seller_id" groups="core_marketplace.marketplace_officer_group"/>
									</div>
                                    <div class="oe_kanban_bottom_right">
                                        <span><field name="product_uom_qty"/></span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

	<record id="view_move_form_for_mp" model="ir.ui.view">
            <field name="name">stock.move.form.for.mp</field>
            <field name="model">stock.move</field>
            <field eval="1" name="priority"/>
            <field name="arch" type="xml">
                <form string="Stock Moves" create="0" edit="0">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,assigned,done" />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <group>
                        <group name="main_grp" colspan="2">
                            <group name="main_grp_col1">
                                <field name="reference"/>
                                <field name="location_id" options="{'no_create': True, 'no_open': True}" readonly="1"/>
                                <field name="location_dest_id" options="{'no_create': True, 'no_open': True}" readonly="1"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group name="main_grp_col2">
                                <field name="product_id" context="{'form_view_ref':'core_marketplace.mp_product_product_form_view'}"/>
                                <field name="product_uom_category_id" invisible="1"/>
                                <label for="product_uom_qty"/>
                                <div class="o_row">
                                    <field name="product_uom_qty"/>
                                    <field name="product_uom" options="{'no_open': True, 'no_create': True}" groups="uom.group_uom"/>
                                </div>
                                <field name="name" invisible="1"/>
                                <div class="o_td_label">
                                    <label for="date" string="Date Scheduled" invisible="state == 'done'"/>
                                    <label for="date" string="Date Processing" invisible="state != 'done'"/>
                                </div>
                                <field name="date" readonly="1" nolabel="1"/>
                                <field name="date_deadline" force_save="1"/>
                            </group>
                        </group>
                        <group name="origin_grp" string="Origin" groups="base.group_no_one" >
                            <field name="origin"/>
                            <field name="group_id"/>
                            <field name="procure_method" readonly="state != 'draft'" groups="stock.group_adv_location"/>
                        </group>
                    </group>
                </sheet>
                </form>
            </field>
		</record>

		<record id="marketplace_product_stock_action2" model="ir.actions.act_window">
			<field name="name">Marketplace Product Stock</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">marketplace.stock</field>
			<field name="binding_view_types">form</field>
			<field name="view_mode">form</field>
			<field name="target">new</field>
		</record>

		<record id="marketplace_product_stock_tree_view" model="ir.ui.view">
			<field name="name">Marketplace Product Stock</field>
			<field name="model">marketplace.stock</field>
			<field name="arch" type="xml">
				<list string="Marketplace Product Stock" decoration-success="state=='approved'" decoration-warning="state=='requested'" decoration-primary="state=='draft'" decoration-danger="state=='rejected'">
					<field name="product_temp_id"/>
					<field name='product_id' groups="core_marketplace.marketplace_officer_group" invisible="1"/>
					<field name='marketplace_seller_id' groups="core_marketplace.marketplace_officer_group"/>
					<field name='new_quantity'/>
					<field name='location_id' groups="core_marketplace.marketplace_officer_group"/>
					<field name='state'/>
					<field name='create_date'/>
				</list>
			</field>
		</record>

		<record model="ir.ui.view" id="marketplace_product_stock_kanban_view">
            <field name="name">Marketplace Product Stock.kanban</field>
            <field name="model">marketplace.stock</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" disable_draggable="true">
                    <field name="product_temp_id"/>
                    <field name="product_id"/>
                    <field name="marketplace_seller_id"/>
                    <field name="new_quantity"/>
                    <field name="location_id"/>
					<field name="state"/>
					<field name="create_date"/>
                    <templates>
                        <t t-name="card">
                            <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                                <div class="o_kanban_record_top mb8">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><span><t t-esc="record.product_id.value"/></span></strong>
                                    </div>
                                    <strong>
										<field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'rejected': 'danger', 'requested': 'warning', 'approved': 'success'}}"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <t t-esc="record.location_id.value"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
										<strong>
											<t t-esc="record.new_quantity.value"/>
										</strong>
                                    </div>
                                </div>
								<div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
										<strong groups="core_marketplace.marketplace_officer_group"> Seller: </strong>
										<field name="marketplace_seller_id" groups="core_marketplace.marketplace_officer_group"/>
									</div>
                                    <div class="oe_kanban_bottom_right">
										<t t-esc="record.create_date.value and record.create_date.value.split(' ')[0] or False"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

		<record id="marketplace_product_stock_form_view" model="ir.ui.view">
			<field name="name">Marketplace Product Stock</field>
			<field name="model">marketplace.stock</field>
			<field name="arch" type="xml">
				<form string="Marketplace Product Stock">
					<header>
						<button name="request" string="Request" type="object" invisible="state != 'draft' or context.get('mp_stock', False)" class="btn-primary"/>
						<button name="approve" string="Approve" type="object" invisible="state != 'requested'" groups="core_marketplace.marketplace_officer_group" class="btn-primary"/>
						<button name="reject" string="Reject" type="object" invisible="state != 'requested'" groups="core_marketplace.marketplace_officer_group"/>
						<button name="set_2_draft" string="Set to Draft" type="object" invisible="state != 'rejected'" class="btn-primary"/>
						<field name="state" widget="statusbar" statusbar_visible="draft,requested,approved,rejected"/>
					</header>
					<sheet>
						<field name="product_variant_count" invisible="1"/>
						<group>
							<field name="name"/>
							<field
								name='product_temp_id'
								string="Product Template"
								invisible="1"
								options="{'no_create_edit': True, 'no_quick_create':True, 'no_open': True}"
								required="1"
								readonly="state not in ('draft')"
								domain="[('marketplace_seller_id', '!=', False),('status','=','approved')]"/>
							<field name='product_id' options="{'no_create_edit': True, 'no_quick_create':True}" context="{'form_view_ref': 'core_marketplace.mp_product_product_form_view'}" required="1" readonly="state not in ('draft')" domain="[('marketplace_seller_id', '!=', False),('status','=','approved')]"/>
							<field name='marketplace_seller_id' readonly="1" options="{'no_open': True}" groups="core_marketplace.marketplace_officer_group"/>
							<field name='new_quantity' readonly="state not in ('draft','requested')"/>
							<field name='location_id' groups="core_marketplace.marketplace_officer_group" options="{'no_open': True}" readonly="state not in ('draft')"/>
							<field name='create_date' invisible="not create_date" readonly="1"/>
							<field name="note" placeholder="Write note..." readonly="state not in ('draft')"/>
						</group>
					</sheet>
					<footer invisible="not context.get('mp_stock', False)">
						<button name="request" string="Request" type="object" invisible="state != 'draft'" class="btn-primary"/>
						or
						<button name="cancel" string="Cancel" class="btn-primary" special="cancel"/>
					</footer>
					<div class="oe_chatter">
						<!-- <field name="message_follower_ids" widget="mail_followers"/> -->
						<field name="message_ids"/>
					</div>
				</form>
			</field>
		</record>

