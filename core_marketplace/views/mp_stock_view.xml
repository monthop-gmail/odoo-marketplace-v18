		<record id="add_seller_in_stock_picking_form_formview" model="ir.ui.view">
            <field name="name">stock.picking.form</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <field name="origin" position="after">
                    <field name="marketplace_seller_id" groups="core_marketplace.marketplace_officer_group" invisible="not marketplace_seller_id"/>
                </field>
            </field>
        </record>

		<!-- Filters -->
		<record id="wk_marketplace_stock_search_view" model="ir.ui.view">
			<field name="name">Marketplace Stock Search</field>
			<field name="model">marketplace.stock</field>
			<field name="priority" eval="100"/>
			<field name="arch" type="xml">
				<search string="Search Stock Request">
                    <field name="product_id" string="Product" filter_domain="['|',('product_id','ilike',self),('product_temp_id','ilike',self)]"/>
                    <field name="marketplace_seller_id" string="Seller"/>
                    <field name="state" string="Status"/>
                    <field name="new_quantity" string="Quantity"/>
					<filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
					<filter string="Requested " name="requested" domain="[('state', '=', 'requested')]"/>
					<filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
					<group string="Group By">
						<filter string="Status" domain="" context="{'group_by':'state'}" name="by_state"/>
						<filter string="Products" name="groupby_products" context="{'group_by':'product_id'}"/>
						<filter string="Date" name="groupby_name" context="{'group_by':'create_date'}"/>
					</group>
				</search>
			</field>
		</record>

		<record id="wk_marketplace_stock_search_view_inherit" model="ir.ui.view">
            <field name="name">Marketplace Stock Add Seller Group By For MP Manager</field>
            <field name="model">marketplace.stock</field>
            <field name="inherit_id" ref="core_marketplace.wk_marketplace_stock_search_view"/>
<field name="arch" type="xml">
				<group position="inside">
					<filter string="Locations" name="locations_filter" context="{'group_by':'location_id'}" groups="core_marketplace.marketplace_officer_group"/>
					<filter string="Seller" context="{'group_by':'marketplace_seller_id'}" name="by_marketplace_seller_id" groups="core_marketplace.marketplace_officer_group"/>
				</group>
            </field>
        </record>

		<!-- Filters -->
		<record id="wk_mp_stock_move_search_fiew" model="ir.ui.view">
			<field name="name">Stock Move</field>
			<field name="model">stock.move</field>
			<field name="priority" eval="100"/>
			<field name="arch" type="xml">
				<search string="Stock Moves">
                    <field name="origin" filter_domain="['|', '|', ('origin', 'ilike', self), ('name', 'ilike', self), ('picking_id', 'ilike', self)]" string="Reference"/>
                    <field name="date" groups="base.group_no_one"/>

                    <filter string="Ready" name="ready" domain="[('state','=','assigned')]" help="Stock moves that are Available (Ready to process)"/>
                    <filter string="To Do" name="future" domain="[('state','in',('assigned','confirmed','waiting'))]" help="Stock moves that are Confirmed, Available or Waiting"/>
                    <filter string="Done" name="done" domain="[('state','=','done')]" help="Stock moves that have been processed"/>
                    <separator/>
                    <filter string="Today" name="today_filter" domain="[('date','&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59))), ('date','&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]" help="Orders processed today or scheduled for today"/>
                    <separator/>
                    <filter string="Incoming" name="incoming" domain="[('location_id.usage', 'not in', ('internal', 'transit')), ('location_dest_id.usage', 'in', ('internal', 'transit'))]"/>
                    <filter string="Outgoing" name="outgoing" domain="[('location_id.usage', 'in', ('internal', 'transit')), ('location_dest_id.usage', 'not in', ('internal', 'transit'))]"/>
                    <field name="product_id"/>
                    <field name="name" string="Location" filter_domain="['|',('location_id','ilike',self),('location_dest_id','ilike',self)]"/>
                    <field name="partner_id" string="Partner"  filter_domain="[('picking_id.partner_id','child_of',self)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Product" name="by_product" domain="[]"  context="{'group_by':'product_id'}"/>
                        <filter string="Picking" name="groupby_picking_id" domain="[]"  context="{'group_by':'picking_id'}"/>
                        <filter string="Source" name="groupby_location_id" domain="[]" context="{'group_by':'location_id'}" groups="stock.group_stock_multi_locations"/>
                        <filter string="Destination" name="groupby_dest_location_id" domain="[]" context="{'group_by':'location_dest_id'}" groups="stock.group_stock_multi_locations"/>
                        <filter string="Status" name="groupby_status" domain="[]" context="{'group_by':'state'}"/>
                        <filter string="Creation" name="groupby_create_date" domain="[]" context="{'group_by':'create_date'}" groups="base.group_no_one"/>
                        <filter string="Scheduled Date" name="groupby_date" domain="[]" context="{'group_by': 'date'}"/>
                    </group>
                </search>
			</field>
		</record>

		<record id="wk_mp_stock_move_search_fiew_inherit" model="ir.ui.view">
            <field name="name">Stock Move Add Seller Group By For MP Manager</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="core_marketplace.wk_mp_stock_move_search_fiew"/>
<field name="arch" type="xml">
				<group position="inside">
					<filter string="Seller" context="{'group_by':'marketplace_seller_id'}" name="by_marketplace_seller_id" groups="core_marketplace.marketplace_officer_group"/>
				</group>
            </field>
        </record>

		<record id="wk_mp_stock_picking_search_fiew" model="ir.ui.view">
			<field name="name">Picking</field>
			<field name="model">stock.picking</field>
			<field name="priority" eval="100"/>
			<field name="arch" type="xml">
				<search string="Picking Lists">
					<field name="name" string="Picking List" filter_domain="['|',('name','ilike', self),('origin','ilike',self)]"/>
					<filter name="draft" string="Draft" domain="[('state','=','draft')]" help="Draft Moves"/>
					<filter name="available" string="Ready" domain="[('state','in',('assigned', 'partially_available'))]" help="Assigned Moves"/>
					<filter name="waiting" string="Waiting Availability" domain="[('state','in', ('confirmed', 'waiting'))]" help="Waiting Moves"/>
					<filter name="confirmed" string="Confirmed" domain="[('state','in', ('confirmed', 'waiting', 'assigned'))]" help="Confirmed Moves"/>
					<filter name="done" string="Done" domain="[('state','=','done')]" help="Pickings already processed"/>
					<separator/>
					<filter name="late" string="Late" domain="[('scheduled_date','&lt;', time.strftime('%%Y-%%m-%%d %%H:%%M:%%S'))]" help="Pickings that are late on scheduled time"/>
                    <separator/>
                    <filter string="My Activities" name="activities_my"
                        domain="[('activity_ids.user_id', '=', uid)]"/>
                    <separator/>
                    <filter string="Late Activities" name="activities_overdue"
                        domain="[('activity_ids.date_deadline', '&lt;', context_today().strftime('%Y-%m-%d'))]"
                        help="Show all records which has next action date is before today"/>
                    <filter string="Today Activities" name="activities_today"
                        domain="[('activity_ids.date_deadline', '=', context_today().strftime('%Y-%m-%d'))]"/>
                    <filter string="Future Activities" name="activities_upcoming_all"
                        domain="[('activity_ids.date_deadline', '&gt;', context_today().strftime('%Y-%m-%d'))
                        ]"/>
                    <field name="partner_id" filter_domain="[('partner_id','child_of',self)]"/>
                    <field name="product_id"/>
                    <field name="picking_type_id"/>
                    <field name="group_id"/>
					<group expand="0" string="Group By">
                        <filter string="Status" name="by_state" domain="[]" context="{'group_by':'state'}"/>
                        <filter string="Order Date" name="groupby_orderdate" domain="[]"  context="{'group_by':'date'}"/>
                        <filter string="Expected Date" name="groupby_exp_date" domain="[]"  context="{'group_by':'scheduled_date'}"/>
                        <filter string="Origin" domain="[]" name="groupby_origin" context="{'group_by':'origin'}"/>
                        <filter string="Operation Type" name="picking_type" domain="[]" context="{'group_by':'picking_type_id'}"/>
                        <filter string="Procurement Group" name="groupby_procurement" domain="[]" context="{'group_by':'group_id'}" groups="core_marketplace.marketplace_officer_group"/>
                    </group>
				</search>
			</field>
		</record>

		<record id="wk_mp_stock_picking_search_fiew_inherit" model="ir.ui.view">
            <field name="name">Stock Move Add Seller Group By For MP Manager</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="core_marketplace.wk_mp_stock_picking_search_fiew"/>
<field name="arch" type="xml">
				<group position="inside">
					<filter string="Seller" context="{'group_by':'marketplace_seller_id'}" name="by_marketplace_seller_id" groups="core_marketplace.marketplace_officer_group"/>
				</group>
            </field>
        </record>

		<record id="marketplace_stock_picking_action" model="ir.actions.act_window">
			<field name="name">Delivery Orders</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">stock.picking</field>
			<field name="binding_view_types">form</field>
			<field name="view_mode">kanban,list,form</field>
			<field name="domain">[('marketplace_seller_id','in',['get_marketplace_seller_id()'])]</field>
			<field name="view_id" ref="stock_picking_stock_tree_view_for_mp"/>
			<field name="context">{'search_default_by_state': 1}</field>
			<field name="search_view_id" ref="wk_mp_stock_picking_search_fiew"/>
            <field name="view_ids"
                eval="[(5, 0, 0),
                    (0, 0, {'sequence': 1, 'view_mode': 'kanban','view_id': ref('picking_stock_kanban_view_for_mp')}),
                    (0, 0, {'sequence': 2, 'view_mode': 'list', 'view_id': ref('stock_picking_stock_tree_view_for_mp')}),
                    (0, 0, {'sequence': 3, 'view_mode': 'form', 'view_id': ref('marketplace_picking_stock_modified_form_view')})
                ]"/>
		</record>

		<record id="wk_seller_delivery_action" model="ir.actions.act_window">
			<field name="name">Stock Moves</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">stock.move</field>
			<field name="binding_view_types">form</field>
			<field name="view_mode">kanban,list,form</field>
			<field name="domain">[('product_id.marketplace_seller_id','!=',False)]</field>
			<field name="view_id" ref="stock_picking_stock_move_tree_view_for_mp"/>
			<field name="context">{'search_default_by_marketplace_seller_id': 1}</field>
			<field name="search_view_id" ref="wk_mp_stock_move_search_fiew"/>
            <field name="view_ids"
                eval="[(5, 0, 0),
                    (0, 0, {'sequence': 1, 'view_mode': 'kanban','view_id': ref('stock_move_kanban_view_for_mp')}),
                    (0, 0, {'sequence': 2, 'view_mode': 'list', 'view_id': ref('stock_picking_stock_move_tree_view_for_mp')}),
                    (0, 0, {'sequence': 3, 'view_mode': 'form', 'view_id': ref('view_move_form_for_mp')})
                    ]"/>
                <!-- (0, 0, {'sequence': 3, 'view_mode': 'form', 'view_id': ref('view_move_form_for_mp')}) -->
		</record>

		<record id="marketplace_product_stock_action" model="ir.actions.act_window">
			<field name="name">Update Marketplace Product Quantity</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">marketplace.stock</field>
			<field name="binding_view_types">form</field>
			<field name="view_mode">kanban,list,form</field>
			<field name="context">{'search_default_by_state': 1}</field>
		</record>

        <!-- Simplified stock.move operations form view for Odoo 18 -->
        <record id="view_stock_move_operations_seller_view" model="ir.ui.view">
            <field name="name">stock.move.operations.seller.form.view</field>
            <field name="model">stock.move</field>
            <field name="priority">1000</field>
            <field name="arch" type="xml">
                <form string="Move Detail">
                    <field name="state" invisible="1"/>
                    <group>
                        <group>
                            <field name="product_id" readonly="1" options="{'no_open': True}"/>
                            <field name="product_uom_qty" string="Demand" readonly="1"/>
                            <field name="quantity" string="Done" readonly="1"/>
                            <field name="product_uom" string="UoM" readonly="1"/>
                        </group>
                    </group>
                    <footer>
                        <button string="Close" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="view_stock_move_operations_officer_view" model="ir.ui.view">
            <field name="name">stock.move.operations.officer.form.view</field>
            <field name="model">stock.move</field>
            <field name="inherit_id" ref="core_marketplace.view_stock_move_operations_seller_view"/>
            <field name="arch" type="xml">
                <field name='product_id' position="attributes">
                    <attribute name="options">{'no_open': False}</attribute>
                </field>
            </field>
        </record>

        <!-- Commented out: view_stock_move_nosuggest_operations_seller_view - incompatible with Odoo 18 -->
        <!--
        <record id="view_stock_move_nosuggest_operations_seller_view" model="ir.ui.view">
            ...
        </record>
        -->

        <record id="mp_inherit_view_stock_move_line_operation_tree" model="ir.ui.view">
            <field name="name">mp.inherit.stock.move.line.operations.tree</field>
            <field name="model">stock.move.line</field>
            <field name="priority">1000</field>
            <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree"/>
<field name="arch" type="xml">
                <field name='location_id' position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </field>
                <field name='location_dest_id' position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </field>
                <field name='lot_id' position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </field>
                <field name='lot_name' position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </field>
                <field name='package_id' position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </field>
                <field name='result_package_id' position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </field>
                <field name='owner_id' position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </field>
            </field>
        </record>
	</data>
</odoo>
