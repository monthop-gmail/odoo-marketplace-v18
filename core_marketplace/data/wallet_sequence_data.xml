<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="sequence_seller_wallet" model="ir.sequence">
            <field name="name">Seller Wallet</field>
            <field name="code">seller.wallet</field>
            <field name="prefix">WLT/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <record id="sequence_seller_withdrawal_request" model="ir.sequence">
            <field name="name">Withdrawal Request</field>
            <field name="code">seller.withdrawal.request</field>
            <field name="prefix">WDR/%(year)s/</field>
            <field name="padding">5</field>
        </record>
    </data>
</odoo>
