<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend Partner Form with LINE Tab -->
    <record id="res_partner_view_form_inherit_line" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.line.buyer</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Add LINE button box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_line_memberships" type="object"
                        class="oe_stat_button" icon="fa-comments"
                        invisible="line_channel_count == 0">
                    <field name="line_channel_count" widget="statinfo" string="LINE Channels"/>
                </button>
            </xpath>

            <!-- Add LINE page in notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="LINE" name="line_info"
                      invisible="not line_user_id and line_channel_count == 0">
                    <group>
                        <group string="LINE Profile">
                            <field name="line_user_id"/>
                            <field name="line_display_name"/>
                            <field name="line_picture_url" widget="url"/>
                        </group>
                        <group string="Source">
                            <field name="source_channel"/>
                            <field name="source_line_channel_id"
                                   invisible="source_channel != 'line'"/>
                            <field name="primary_line_channel_id"/>
                        </group>
                    </group>
                    <group string="Notification Preferences">
                        <group>
                            <field name="line_notify_orders"/>
                            <field name="line_notify_promotions"/>
                        </group>
                    </group>
                    <group string="LINE Memberships">
                        <field name="line_member_ids" nolabel="1">
                            <list>
                                <field name="channel_id"/>
                                <field name="display_name"/>
                                <field name="is_following"/>
                                <field name="follow_date"/>
                                <field name="order_count"/>
                            </list>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Add LINE columns to Partner List View -->
    <record id="res_partner_view_tree_inherit_line" model="ir.ui.view">
        <field name="name">res.partner.tree.inherit.line.buyer</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email']" position="after">
                <field name="line_user_id" optional="hide"/>
                <field name="source_channel" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- Add LINE filters to Partner Search View -->
    <record id="res_partner_view_search_inherit_line" model="ir.ui.view">
        <field name="name">res.partner.search.inherit.line.buyer</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='customer']" position="after">
                <separator/>
                <filter string="LINE Users" name="line_users"
                        domain="[('line_user_id', '!=', False)]"/>
                <filter string="From LINE" name="from_line"
                        domain="[('source_channel', '=', 'line')]"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter string="Source Channel" name="group_source"
                        context="{'group_by': 'source_channel'}"/>
            </xpath>
        </field>
    </record>
</odoo>
