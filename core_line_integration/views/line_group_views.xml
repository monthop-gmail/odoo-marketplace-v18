<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LINE Group Tree View -->
    <record id="line_group_view_tree" model="ir.ui.view">
        <field name="name">line.group.tree</field>
        <field name="model">line.group</field>
        <field name="arch" type="xml">
            <tree string="LINE Groups">
                <field name="display_name"/>
                <field name="group_type"/>
                <field name="channel_id"/>
                <field name="is_active" widget="boolean_toggle"/>
                <field name="member_count"/>
                <field name="known_member_count"/>
                <field name="joined_date"/>
                <field name="left_date"/>
            </tree>
        </field>
    </record>

    <!-- LINE Group Form View -->
    <record id="line_group_view_form" model="ir.ui.view">
        <field name="name">line.group.form</field>
        <field name="model">line.group</field>
        <field name="arch" type="xml">
            <form string="LINE Group">
                <header>
                    <button name="action_fetch_group_info" type="object"
                            string="Fetch Group Info" class="btn-primary"
                            invisible="not is_active or group_type != 'group'"/>
                    <button name="action_leave_group" type="object"
                            string="Leave Group" class="btn-danger"
                            invisible="not is_active"
                            confirm="Are you sure you want the bot to leave this group?"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(core_line_integration.line_group_member_action)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-users"
                                context="{'search_default_group_id': active_id}">
                            <field name="known_member_count" widget="statinfo" string="Known Members"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-danger"
                            invisible="is_active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Group Info">
                            <field name="name"/>
                            <field name="line_group_id"/>
                            <field name="group_type"/>
                            <field name="picture_url" widget="url"/>
                            <field name="is_active"/>
                        </group>
                        <group string="Channel &amp; Stats">
                            <field name="channel_id"/>
                            <field name="channel_code"/>
                            <field name="member_count"/>
                            <field name="joined_date"/>
                            <field name="left_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Known Members" name="members">
                            <field name="group_member_ids">
                                <tree string="Members">
                                    <field name="display_name"/>
                                    <field name="line_user_id"/>
                                    <field name="partner_id"/>
                                    <field name="is_in_group" widget="boolean_toggle"/>
                                    <field name="joined_date"/>
                                    <field name="left_date"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes about this group..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LINE Group Search View -->
    <record id="line_group_view_search" model="ir.ui.view">
        <field name="name">line.group.search</field>
        <field name="model">line.group</field>
        <field name="arch" type="xml">
            <search string="LINE Groups">
                <field name="name"/>
                <field name="line_group_id"/>
                <field name="channel_id"/>
                <filter name="active_groups" string="Active" domain="[('is_active', '=', True)]"/>
                <filter name="inactive_groups" string="Inactive" domain="[('is_active', '=', False)]"/>
                <separator/>
                <filter name="groups_only" string="Groups" domain="[('group_type', '=', 'group')]"/>
                <filter name="rooms_only" string="Rooms" domain="[('group_type', '=', 'room')]"/>
                <group expand="0" string="Group By">
                    <filter name="groupby_channel" string="Channel" context="{'group_by': 'channel_id'}"/>
                    <filter name="groupby_type" string="Type" context="{'group_by': 'group_type'}"/>
                    <filter name="groupby_active" string="Status" context="{'group_by': 'is_active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- LINE Group Action -->
    <record id="line_group_action" model="ir.actions.act_window">
        <field name="name">LINE Groups</field>
        <field name="res_model">line.group</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active_groups': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No LINE groups yet
            </p>
            <p>
                Groups will appear here when the bot is invited to LINE group chats.
            </p>
        </field>
    </record>

    <!-- LINE Group Member Action -->
    <record id="line_group_member_action" model="ir.actions.act_window">
        <field name="name">Group Members</field>
        <field name="res_model">line.group.member</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- LINE Group Member Tree View -->
    <record id="line_group_member_view_tree" model="ir.ui.view">
        <field name="name">line.group.member.tree</field>
        <field name="model">line.group.member</field>
        <field name="arch" type="xml">
            <tree string="Group Members">
                <field name="display_name"/>
                <field name="group_id"/>
                <field name="line_user_id"/>
                <field name="partner_id"/>
                <field name="channel_member_id"/>
                <field name="is_in_group" widget="boolean_toggle"/>
                <field name="joined_date"/>
                <field name="left_date"/>
            </tree>
        </field>
    </record>

    <!-- LINE Group Member Form View -->
    <record id="line_group_member_view_form" model="ir.ui.view">
        <field name="name">line.group.member.form</field>
        <field name="model">line.group.member</field>
        <field name="arch" type="xml">
            <form string="Group Member">
                <sheet>
                    <group>
                        <group string="Member Info">
                            <field name="display_name"/>
                            <field name="line_user_id"/>
                            <field name="picture_url" widget="url"/>
                            <field name="group_id"/>
                        </group>
                        <group string="Links &amp; Status">
                            <field name="channel_member_id"/>
                            <field name="partner_id"/>
                            <field name="is_in_group"/>
                            <field name="joined_date"/>
                            <field name="left_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
