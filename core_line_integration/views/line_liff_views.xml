<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- LINE LIFF Tree View -->
    <record id="line_liff_view_tree" model="ir.ui.view">
        <field name="name">line.liff.tree</field>
        <field name="model">line.liff</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="liff_id"/>
                <field name="liff_type" widget="badge"
                       decoration-info="liff_type == 'buyer'"
                       decoration-success="liff_type == 'seller'"
                       decoration-warning="liff_type == 'admin'"
                       decoration-danger="liff_type == 'promotion'"/>
                <field name="liff_size"/>
                <field name="channel_id"/>
                <field name="liff_url" widget="url"/>
                <field name="access_count"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- LINE LIFF Form View -->
    <record id="line_liff_view_form" model="ir.ui.view">
        <field name="name">line.liff.form</field>
        <field name="model">line.liff</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_liff" type="object"
                            string="Open LIFF" class="oe_highlight"
                            icon="fa-external-link"
                            invisible="not liff_url"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Buyer App"/>
                        </h1>
                    </div>

                    <group>
                        <group string="LIFF Configuration">
                            <field name="liff_id" placeholder="1234567890-AbCdEfGh"/>
                            <field name="liff_url" widget="CopyClipboardChar"/>
                            <field name="liff_type"/>
                            <field name="liff_size"/>
                            <field name="sequence"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Channel">
                            <field name="channel_id"/>
                            <field name="channel_code"/>
                            <field name="endpoint_url" widget="url" placeholder="https://your-domain.com/liff"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Features" name="features">
                            <group>
                                <group string="Enabled Features">
                                    <field name="feature_browse_products"/>
                                    <field name="feature_cart"/>
                                    <field name="feature_checkout"/>
                                    <field name="feature_order_history"/>
                                    <field name="feature_profile"/>
                                </group>
                                <group string="Statistics">
                                    <field name="access_count"/>
                                    <field name="last_access_date"/>
                                </group>
                            </group>
                            <div class="alert alert-info" role="alert">
                                <strong>Feature Flags:</strong>
                                <p>Enable or disable features for this LIFF app.
                                The LIFF frontend can read these settings via API
                                to show/hide UI elements accordingly.</p>
                            </div>
                        </page>

                        <page string="Notes" name="notes">
                            <group>
                                <field name="description" placeholder="Description of this LIFF app..."/>
                            </group>
                            <group>
                                <field name="notes" placeholder="Internal notes..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- LINE LIFF Kanban View -->
    <record id="line_liff_view_kanban" model="ir.ui.view">
        <field name="name">line.liff.kanban</field>
        <field name="model">line.liff</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="liff_id"/>
                <field name="liff_type"/>
                <field name="liff_size"/>
                <field name="liff_url"/>
                <field name="access_count"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_title">
                                <field name="name"/>
                            </div>
                            <div class="text-muted small">
                                <field name="liff_id"/>
                            </div>
                            <div class="mt-2">
                                <span t-attf-class="badge #{liff_type == 'buyer' ? 'bg-info' : liff_type == 'seller' ? 'bg-success' : liff_type == 'admin' ? 'bg-warning' : 'bg-secondary'}">
                                    <field name="liff_type"/>
                                </span>
                                <span class="badge bg-light text-dark">
                                    <field name="liff_size"/>
                                </span>
                            </div>
                            <div class="mt-2 text-muted small">
                                <i class="fa fa-eye"/> <field name="access_count"/> accesses
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- LINE LIFF Search View -->
    <record id="line_liff_view_search" model="ir.ui.view">
        <field name="name">line.liff.search</field>
        <field name="model">line.liff</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="liff_id"/>
                <field name="channel_id"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Buyer Apps" name="buyer" domain="[('liff_type', '=', 'buyer')]"/>
                <filter string="Seller Apps" name="seller" domain="[('liff_type', '=', 'seller')]"/>
                <filter string="Admin Apps" name="admin" domain="[('liff_type', '=', 'admin')]"/>
                <group expand="0" string="Group By">
                    <filter string="Channel" name="channel" context="{'group_by': 'channel_id'}"/>
                    <filter string="Type" name="type" context="{'group_by': 'liff_type'}"/>
                    <filter string="Size" name="size" context="{'group_by': 'liff_size'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- LINE LIFF Action -->
    <record id="line_liff_action" model="ir.actions.act_window">
        <field name="name">LIFF Apps</field>
        <field name="res_model">line.liff</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first LIFF App
            </p>
            <p>
                LIFF (LINE Front-end Framework) apps are web apps that run inside LINE.
                Each LINE channel can have up to 30 LIFF apps for different purposes:
                buyer interface, seller dashboard, admin panel, etc.
            </p>
        </field>
    </record>

    <!-- Update LINE Channel Form to show LIFF Apps -->
    <record id="line_channel_view_form_liff" model="ir.ui.view">
        <field name="name">line.channel.form.liff</field>
        <field name="model">line.channel</field>
        <field name="inherit_id" ref="core_line_integration.line_channel_view_form"/>
        <field name="arch" type="xml">
            <!-- Add LIFF Apps stat button -->
            <xpath expr="//button[@name='action_view_members']" position="after">
                <button name="action_view_liffs" type="object"
                        class="oe_stat_button" icon="fa-mobile">
                    <field name="liff_count" widget="statinfo" string="LIFF Apps"/>
                </button>
            </xpath>

            <!-- Replace LIFF Configuration tab content -->
            <xpath expr="//page[@name='liff']" position="replace">
                <page string="LIFF Apps" name="liff">
                    <div class="alert alert-info" role="alert" invisible="liff_count > 0">
                        <strong>No LIFF Apps configured.</strong>
                        <p>Click the button below to create LIFF apps for buyers, sellers, or admins.</p>
                        <button name="action_view_liffs" type="object" string="Manage LIFF Apps" class="btn btn-primary"/>
                    </div>

                    <field name="liff_ids" invisible="liff_count == 0">
                        <list>
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="liff_id"/>
                            <field name="liff_type" widget="badge"
                                   decoration-info="liff_type == 'buyer'"
                                   decoration-success="liff_type == 'seller'"
                                   decoration-warning="liff_type == 'admin'"/>
                            <field name="liff_size"/>
                            <field name="liff_url" widget="url"/>
                            <field name="access_count"/>
                        </list>
                    </field>

                    <!-- Legacy LIFF fields (collapsed, for backward compatibility) -->
                    <group string="Legacy LIFF Configuration (Deprecated)" invisible="not liff_id">
                        <div class="alert alert-warning" role="alert">
                            <strong>Legacy Configuration Detected:</strong>
                            <p>This channel uses the old single-LIFF configuration.
                            Please migrate to the new LIFF Apps system above for better management.</p>
                        </div>
                        <group>
                            <field name="liff_id"/>
                            <field name="liff_url" widget="url"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
