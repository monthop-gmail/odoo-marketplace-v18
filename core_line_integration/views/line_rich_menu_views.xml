<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Rich Menu List View -->
    <record id="line_rich_menu_tree" model="ir.ui.view">
        <field name="name">line.rich.menu.tree</field>
        <field name="model">line.rich.menu</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'active'" decoration-muted="state == 'archived'">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="channel_id"/>
                <field name="menu_type"/>
                <field name="size"/>
                <field name="chat_bar_text"/>
                <field name="rich_menu_id"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'uploaded'"
                       decoration-success="state == 'active'"
                       decoration-muted="state == 'archived'"/>
            </list>
        </field>
    </record>

    <!-- Rich Menu Form View -->
    <record id="line_rich_menu_form" model="ir.ui.view">
        <field name="name">line.rich.menu.form</field>
        <field name="model">line.rich.menu</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_on_line" string="Upload to LINE"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_set_default" string="Set as Default"
                            type="object" class="btn-primary"
                            invisible="state not in ('uploaded', 'active')"/>
                    <button name="action_delete_on_line" string="Delete from LINE"
                            type="object" class="btn-danger"
                            invisible="not rich_menu_id"
                            confirm="Are you sure you want to delete this rich menu from LINE?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,uploaded,active"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_preview" type="object"
                                class="oe_stat_button" icon="fa-eye">
                            <span>Preview</span>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Default"
                            bg_color="text-bg-success"
                            invisible="state != 'active'"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Menu Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Settings">
                            <field name="channel_id"/>
                            <field name="menu_type"/>
                            <field name="size"/>
                            <field name="width" readonly="1"/>
                            <field name="height" readonly="1"/>
                            <field name="chat_bar_text"/>
                            <field name="selected"/>
                            <field name="active"/>
                        </group>
                        <group string="LINE Info">
                            <field name="rich_menu_id" readonly="1"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <group string="Menu Image">
                        <field name="image" widget="image" class="oe_avatar"/>
                        <field name="image_filename" invisible="1"/>
                        <p class="text-muted">
                            Image requirements: JPEG or PNG, 2500x1686 (Full) or 2500x843 (Half), max 1MB
                        </p>
                    </group>
                    <notebook>
                        <page string="Menu Areas" name="areas">
                            <field name="area_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="x"/>
                                    <field name="y"/>
                                    <field name="area_width"/>
                                    <field name="area_height"/>
                                    <field name="action_type"/>
                                    <field name="action_uri" invisible="action_type != 'uri'"/>
                                    <field name="action_text" invisible="action_type != 'message'"/>
                                    <field name="liff_id" invisible="action_type != 'liff'"/>
                                </list>
                            </field>
                            <div class="alert alert-info" role="alert">
                                <strong>Grid Layout Guide (Full Size 2500x1686):</strong>
                                <ul class="mb-0">
                                    <li>3 columns: Each 833px wide (x: 0, 833, 1666)</li>
                                    <li>2 rows: Each 843px tall (y: 0, 843)</li>
                                    <li>6 areas total for a 3x2 grid</li>
                                </ul>
                            </div>
                        </page>
                        <page string="Targeting" name="targeting">
                            <group>
                                <field name="target_type"/>
                                <field name="target_member_ids" widget="many2many_tags"
                                       invisible="target_type != 'specific'"/>
                            </group>
                        </page>
                        <page string="Scheduling" name="scheduling">
                            <group>
                                <field name="is_scheduled"/>
                                <field name="schedule_start" invisible="not is_scheduled"/>
                                <field name="schedule_end" invisible="not is_scheduled"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Rich Menu Area Form -->
    <record id="line_rich_menu_area_form" model="ir.ui.view">
        <field name="name">line.rich.menu.area.form</field>
        <field name="model">line.rich.menu.area</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group string="Position">
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="x"/>
                        <field name="y"/>
                        <field name="area_width"/>
                        <field name="area_height"/>
                    </group>
                    <group string="Action">
                        <field name="action_type"/>
                        <field name="action_uri" invisible="action_type != 'uri'"/>
                        <field name="action_text" invisible="action_type != 'message'"/>
                        <field name="action_data" invisible="action_type not in ('postback', 'richmenuswitch')"/>
                        <field name="action_display_text" invisible="action_type != 'postback'"/>
                        <field name="liff_id" invisible="action_type != 'liff'"
                               domain="[('channel_id', '=', parent.channel_id)]"/>
                        <field name="target_rich_menu_id" invisible="action_type != 'richmenuswitch'"
                               domain="[('channel_id', '=', parent.channel_id)]"/>
                        <field name="target_rich_menu_alias" invisible="action_type != 'richmenuswitch'"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- Preview Form (popup) -->
    <record id="line_rich_menu_preview_form" model="ir.ui.view">
        <field name="name">line.rich.menu.preview.form</field>
        <field name="model">line.rich.menu</field>
        <field name="arch" type="xml">
            <form>
                <div style="text-align: center;">
                    <h3><field name="name" readonly="1"/></h3>
                    <p>Size: <field name="width" readonly="1"/> x <field name="height" readonly="1"/></p>
                    <field name="image" widget="image" readonly="1"
                           style="max-width: 500px; border: 1px solid #ddd;"/>
                    <div class="mt-3">
                        <h4>Menu Areas:</h4>
                        <field name="area_ids" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="action_type"/>
                                <field name="x"/>
                                <field name="y"/>
                                <field name="area_width"/>
                                <field name="area_height"/>
                            </list>
                        </field>
                    </div>
                </div>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="line_rich_menu_search" model="ir.ui.view">
        <field name="name">line.rich.menu.search</field>
        <field name="model">line.rich.menu</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="channel_id"/>
                <field name="rich_menu_id"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Uploaded" name="uploaded" domain="[('state', '=', 'uploaded')]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <group expand="0" string="Group By">
                    <filter string="Channel" name="group_channel" context="{'group_by': 'channel_id'}"/>
                    <filter string="Menu Type" name="group_menu_type" context="{'group_by': 'menu_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Size" name="group_size" context="{'group_by': 'size'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="line_rich_menu_action" model="ir.actions.act_window">
        <field name="name">Rich Menus</field>
        <field name="res_model">line.rich.menu</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first LINE Rich Menu
            </p>
            <p>
                Rich menus provide a customizable menu interface at the bottom
                of the chat screen for your LINE users.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_line_rich_menu"
              name="Rich Menus"
              parent="menu_line_buyer_config"
              action="line_rich_menu_action"
              sequence="30"/>
</odoo>
