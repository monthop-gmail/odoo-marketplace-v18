<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- LINE Notification Processing Cron -->
        <record id="ir_cron_process_line_notifications" model="ir.cron">
            <field name="name">LINE: Process Pending Notifications</field>
            <field name="model_id" ref="model_line_notify_log"/>
            <field name="state">code</field>
            <field name="code">model.process_pending_notifications()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- LINE Member Cleanup Cron (remove inactive unfollowed members) -->
        <record id="ir_cron_cleanup_line_members" model="ir.cron">
            <field name="name">LINE: Cleanup Inactive Members</field>
            <field name="model_id" ref="model_line_channel_member"/>
            <field name="state">code</field>
            <field name="code">model.cleanup_inactive_members()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">False</field>
        </record>
    </data>
</odoo>
