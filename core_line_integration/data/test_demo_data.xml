            <field name="channel_access_token">test_token_organic_qrstuvwxyz</field>
            <field name="active">True</field>
        </record>

        <!-- ========================================
             Test LIFF Apps
             ======================================== -->

        <!-- Channel 1 LIFF Apps -->
        <record id="test_liff_buyer_1" model="line.liff">
            <field name="name">Farm Fresh Buyer App</field>
            <field name="liff_id">1234567890-FarmBuyer</field>
            <field name="channel_id" ref="test_line_channel_1"/>
            <field name="liff_type">buyer</field>
            <field name="liff_size">full</field>
            <field name="feature_browse_products">True</field>
            <field name="feature_cart">True</field>
            <field name="feature_checkout">True</field>
            <field name="feature_order_history">True</field>
            <field name="feature_profile">True</field>
            <field name="active">True</field>
        </record>

        <record id="test_liff_seller_1" model="line.liff">
            <field name="name">Farm Fresh Seller App</field>
            <field name="liff_id">1234567890-FarmSellr</field>
            <field name="channel_id" ref="test_line_channel_1"/>
            <field name="liff_type">seller</field>
            <field name="liff_size">full</field>
            <field name="active">True</field>
        </record>

        <!-- Channel 2 LIFF Apps -->
        <record id="test_liff_buyer_2" model="line.liff">
            <field name="name">Organic Valley Buyer App</field>
            <field name="liff_id">0987654321-OrgBuyer</field>
            <field name="channel_id" ref="test_line_channel_2"/>
            <field name="liff_type">buyer</field>
            <field name="liff_size">full</field>
            <field name="feature_browse_products">True</field>
            <field name="feature_cart">True</field>
            <field name="feature_checkout">True</field>
            <field name="feature_order_history">True</field>
            <field name="feature_profile">True</field>
            <field name="active">True</field>
        </record>

        <!-- ========================================
             Test LINE Channel Members (Buyers)
             ======================================== -->

        <record id="test_line_member_1" model="line.channel.member">
            <field name="line_user_id">U1234567890abcdef1234567890abcdef</field>
            <field name="channel_id" ref="test_line_channel_1"/>
            <field name="display_name">TestUser1</field>
            <field name="status_message">Testing LINE integration</field>
            <field name="is_following">True</field>
        </record>

        <record id="test_line_member_2" model="line.channel.member">
            <field name="line_user_id">Uabcdef1234567890abcdef1234567890</field>
            <field name="channel_id" ref="test_line_channel_1"/>
            <field name="display_name">TestUser2</field>
            <field name="is_following">True</field>
        </record>

        <record id="test_line_member_3" model="line.channel.member">
            <field name="line_user_id">U0987654321fedcba0987654321fedcba</field>
            <field name="channel_id" ref="test_line_channel_2"/>
            <field name="display_name">OrgUser1</field>
            <field name="is_following">True</field>
        </record>

        <!-- Unfollowed member for testing -->
        <record id="test_line_member_unfollowed" model="line.channel.member">
            <field name="line_user_id">Uunfollowed123456789012345678901234</field>
            <field name="channel_id" ref="test_line_channel_1"/>
            <field name="display_name">UnfollowedUser</field>
            <field name="is_following">False</field>
        </record>

        <!-- ========================================
             Test Rich Menus
             ======================================== -->

        <record id="test_rich_menu_1" model="line.rich.menu">
            <field name="name">Main Menu - Farm Fresh</field>
            <field name="channel_id" ref="test_line_channel_1"/>
            <field name="size">full</field>
            <field name="selected">True</field>
            <field name="chat_bar_text">เมนู</field>
            <field name="state">draft</field>
        </record>

        <record id="test_rich_menu_2" model="line.rich.menu">
            <field name="name">Main Menu - Organic Valley</field>
            <field name="channel_id" ref="test_line_channel_2"/>
            <field name="size">full</field>
            <field name="selected">True</field>
            <field name="chat_bar_text">เมนูหลัก</field>
            <field name="state">draft</field>
        </record>

    </data>
