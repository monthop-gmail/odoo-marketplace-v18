<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ========================================
             Test LINE Channels
             ======================================== -->

        <record id="test_line_channel_1" model="line.channel">
            <field name="name">สหกรณ์ฟาร์มเฟรช OA</field>
            <field name="code">farmfresh_oa</field>
            <field name="channel_id">1234567890</field>
            <field name="channel_secret">test_secret_farmfresh_12345</field>
            <field name="channel_access_token">test_token_farmfresh_abcdefghijklmnop</field>
            <field name="active">True</field>
        </record>

        <record id="test_line_channel_2" model="line.channel">
            <field name="name">สหกรณ์ออร์แกนิค วัลเลย์ OA</field>
            <field name="code">organic_valley_oa</field>
            <field name="channel_id">0987654321</field>
